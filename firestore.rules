rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Safety Helpers
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // 3. Entity Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt']) &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is timestamp &&
             data.keys().hasOnly(['email', 'displayName', 'photoURL', 'createdAt']) &&
             (data.get('displayName', '') is string) && (data.get('displayName', '').size() <= 128) &&
             (data.get('photoURL', '') is string) && (data.get('photoURL', '').size() <= 2048);
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'status', 'priority', 'userId', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 256 &&
             (data.get('description', '') is string) && (data.get('description', '').size() <= 4096) &&
             data.status in ['Pending', 'In Progress', 'Completed'] &&
             data.priority in ['Low', 'Medium', 'High'] &&
             data.userId == request.auth.uid && // Must belong to caller
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.keys().hasOnly(['title', 'description', 'status', 'priority', 'userId', 'createdAt', 'updatedAt']);
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 256 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp &&
             data.keys().hasOnly(['userId', 'title', 'createdAt', 'updatedAt']);
    }

    function isValidMessage(data) {
       return data.keys().hasAll(['role', 'content', 'createdAt']) &&
              data.role in ['user', 'model', 'system'] &&
              data.content is string && data.content.size() <= 65536 &&
              data.createdAt is timestamp &&
              data.keys().hasOnly(['role', 'content', 'createdAt']);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'message', 'type', 'isRead', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.message is string && data.message.size() <= 512 &&
             data.type in ['task', 'ai', 'alert'] &&
             data.isRead is bool &&
             data.createdAt is timestamp &&
             data.keys().hasOnly(['userId', 'message', 'type', 'isRead', 'createdAt']);
    }

    // 4. Collection Rules
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) &&
                    isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId) &&
                    isValidUser(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
      allow delete: if false; // Users shouldn't be deleted via client SDK directly
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(taskId) && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(taskId) &&
                    isValidTask(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isValidId(taskId) &&
                    existing().userId == request.auth.uid &&
                    isValidTask(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'status', 'priority', 'updatedAt']);
      allow delete: if isSignedIn() && isValidId(taskId) && existing().userId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(chatId) && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(chatId) &&
                    isValidChat(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isValidId(chatId) &&
                    existing().userId == request.auth.uid &&
                    isValidChat(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']);
      allow delete: if isSignedIn() && isValidId(chatId) && existing().userId == request.auth.uid;
      
      match /messages/{messageId} {
         allow list: if isSignedIn() && isValidId(chatId) &&
                     get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
         allow get: if isSignedIn() && isValidId(chatId) && isValidId(messageId) &&
                    get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid;
         allow create: if isSignedIn() && isValidId(chatId) && isValidId(messageId) &&
                       get(/databases/$(database)/documents/chats/$(chatId)).data.userId == request.auth.uid &&
                       isValidMessage(incoming()) &&
                       incoming().createdAt == request.time;
         allow update: if false; // Messages are immutable
         allow delete: if false; // Individual messages are not deleted
      }
    }

    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && isValidId(notificationId) && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(notificationId) &&
                    isValidNotification(incoming()) &&
                    incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(notificationId) &&
                    existing().userId == request.auth.uid &&
                    isValidNotification(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().type == existing().type &&
                    incoming().message == existing().message &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn() && isValidId(notificationId) && existing().userId == request.auth.uid;
    }

  }
}
